# Copie este arquivo para .env e preencha com suas credenciais
# NUNCA suba o arquivo .env para o GitHub!

# Banco principal (recomendado: Supabase/PostgreSQL)
DATABASE_URL=postgresql://postgres:SUA-SENHA@db.PROJETO.supabase.co:5432/postgres

# Alias aceito pelo projeto
# SUPABASE_DB_URL=postgresql://postgres:SUA-SENHA@db.PROJETO.supabase.co:5432/postgres

# Opcional para PostgreSQL/Supabase
DB_SSLMODE=require

